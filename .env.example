# LLM settings
YT_LLM_MODEL=phi3:mini
YT_LLM_TEMPERATURE=0.5
YT_LLM_MAX_TOKENS=256
YT_LLM_TIMEOUT_SECONDS=60
YT_LLM_RETRY_ATTEMPTS=2

# Embedding settings
YT_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
YT_EMBEDDING_DEVICE=cpu
YT_NORMALIZE_EMBEDDINGS=true

# Retrieval settings
YT_CHUNK_SIZE=1000
YT_CHUNK_OVERLAP=200
YT_RETRIEVAL_TOP_K=7

# Logging settings
YT_LOG_LEVEL=INFO
YT_LOG_JSON=true

# FastAPI settings
YT_API_HOST=0.0.0.0
YT_API_PORT=8000

# Gradio UI settings
YT_GRADIO_HOST=0.0.0.0
YT_GRADIO_PORT=7865
